TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHANNEL_ID=-1000000000000
ADMIN_IDS=12345678,87654321

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-sua-chave-aqui
OPENAI_MODEL=gpt-4o-mini
# Se quiser usar uma base URL customizada (proxy, servidor local, etc.)
# Deixe em branco para usar a oficial da OpenAI
OPENAI_BASE_URL=

# ── Afiliados ───────────────────────────────────────────────────────────────
# IDs por loja — deixe em branco para desativar a injeção automática
AFFILIATE_ID_AMAZON=seu_tag_amazon-20
AFFILIATE_ID_ML=seu_perfil_ml
AFFILIATE_ID_MAGALU=nome_da_sua_loja_magalu
AFFILIATE_ID_NETSHOES=seu_id_netshoes

# ── Encurtador de links ──────────────────────────────────────────────────────
# Backend padrão: tinyurl | isgd | simulated
SHORTENER_BACKEND=tinyurl

# ── WhatsApp API (Evolution API / Uazapi) ───────────────────────────────────
WPP_API_URL=https://sua-api.com
WPP_API_KEY=seu-token-aqui
WPP_INSTANCE=achadinhos

# ── WhatsApp ─────────────────────────────────────────────────────────────────
# URL do canal do WhatsApp para exibir no rodapé do copy
WHATSAPP_CHANNEL_URL=https://wa.me/channel/SEU_LINK_AQUI

# ── Fase 3: Scheduler de monitoramento ───────────────────────────────────────
# Intervalo em MINUTOS entre cada varredura automática das fontes
# Padrão: 60 (a cada 1 hora)
MONITOR_INTERVAL_MINUTES=60

# Se true, publica automaticamente sem pedir aprovação do admin.
# Mantenha false na Fase 3 para controle manual. Será útil na Fase 4.
AUTO_APPROVE=false
